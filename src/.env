# ============================================
# Docker Compose 运行环境配置
# ============================================

# AzerothCore 镜像 tag；留空时使用上游 compose 默认值。
DOCKER_IMAGE_TAG=

# AzerothCore 容器内部环境文件路径；留空时使用上游 compose 默认值。
DOCKER_AC_ENV_FILE=

# Docker 卷根目录；留空时使用上游 compose 默认值。
DOCKER_VOL_ROOT=

# AzerothCore conf 目录挂载路径；留空时使用上游 compose 默认值。
DOCKER_VOL_CONF=

# AzerothCore etc 配置挂载目录；映射到宿主机 wotlk/etc。
DOCKER_VOL_ETC=../../wotlk/etc

# AzerothCore 日志挂载目录；映射到宿主机 wotlk/logs。
DOCKER_VOL_LOGS=../../wotlk/logs

# 客户端数据挂载目录；映射到宿主机 wotlk/client。
DOCKER_VOL_DATA=../../wotlk/client

# MySQL 数据目录；映射到宿主机 wotlk/database/mysql。
DOCKER_VOL_DB=../../wotlk/database/mysql

# MySQL 配置目录；映射到宿主机 wotlk/database/conf.d。
DOCKER_VOL_DB_CNF=../../wotlk/database/conf.d

# 客户端原始文件目录；当前脚本使用预下载 client-data，通常留空。
DOCKER_AC_CLIENT_FOLDER=

# ALE Lua 脚本挂载目录；映射到宿主机 wotlk/lua_scripts。
WOTLK_LUA_SCRIPT_DIR=../../wotlk/lua_scripts

# worldserver 对外端口。
DOCKER_WORLD_EXTERNAL_PORT=8085

# SOAP 对外端口。
DOCKER_SOAP_EXTERNAL_PORT=7878

# authserver 登录端口。
DOCKER_AUTH_EXTERNAL_PORT=3724

# MySQL root 密码；脚本执行数据库初始化和 realmlist 配置时会使用。
DOCKER_DB_ROOT_PASSWORD=password

# 容器内运行 AzerothCore 的用户名。
DOCKER_USER=acore

# 容器内运行用户 UID；需要和脚本 chown 的 1000 保持一致。
DOCKER_USER_ID=1000

# 容器内运行用户 GID；需要和脚本 chown 的 1000 保持一致。
DOCKER_GROUP_ID=1000

# 容器时区；configure_core 会尽量按宿主机 /etc/timezone 自动更新。
TZ=Asia/Shanghai

# ============================================
# 以下内容由 ac.sh 自动生成，不建议手工修改。
# 下一次 install/update/toggle 可能会覆盖该区域。
# ============================================
# BEGIN ACORE AUTO MEMORY
AC_MEMORY_TOTAL_MB=8192
AC_MEMORY_USED_MB=1061
AC_BUILD_RESERVED_MB=1573
AC_RUNTIME_RESERVED_MB=1573
AC_DATABASE_MEMORY_LIMIT=1920m
AC_WORLDSERVER_MEMORY_LIMIT=3419m
AC_AUTHSERVER_MEMORY_LIMIT=512m
AC_CLIENT_DATA_INIT_MEMORY_LIMIT=768m
AC_DATABASE_INNODB_BUFFER_POOL_SIZE=960M
AC_RUNTIME_DOCKERFILE=/data/acore/build/acore-runtime/Dockerfile
# END ACORE AUTO MEMORY
